PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/parklog
CORS_ORIGIN=*
DEFAULT_LOT_ID=adtu-main
DEFAULT_BLOCK=A
STALE_AFTER_SECONDS=45

# Set REQUIRE_DEVICE_API_KEY=true in production and copy this key into ESP32 config.h.
REQUIRE_DEVICE_API_KEY=false
DEVICE_API_KEY=change-me

# Optional OTA metadata served by GET /api/ota/latest
OTA_VERSION=0.0.0
OTA_URL=
OTA_CHECKSUM=
OTA_REQUIRED=false
